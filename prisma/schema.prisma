generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
}

enum VehicleType {
  TRUCK
  MINI_TRUCK
  TRAILER
  CONTAINER
  TANKER
  OTHER
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String      @id @default(cuid())
  vehicleNumber      String      @unique
  vehicleType        VehicleType @default(OTHER)
  ownerName          String
  monthlyTax         Float       @default(0)
  insuranceNumber    String?
  insuranceStartDate DateTime?
  insuranceExpiry    DateTime?
  permitDetails      String?
  fitnessExpiry      DateTime?
  pollutionExpiry    DateTime?
  photoUrl           String?
  notes              String?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  trips              Trip[]
  drivers            Driver[]
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  mobile          String
  address         String?
  licenseNumber   String?
  licenseExpiry   DateTime?
  salary          Float        @default(0)
  advanceBalance  Float        @default(0)
  joiningDate     DateTime?
  status          DriverStatus @default(ACTIVE)
  assignedVehicle Vehicle?     @relation(fields: [vehicleId], references: [id])
  vehicleId       String?
  photoUrl        String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  trips           Trip[]
}

model Party {
  id             String    @id @default(cuid())
  partyName      String
  contactPerson  String?
  mobile         String?
  address        String?
  gstNumber      String?
  billingAddress String?
  paymentTerms   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  trips          Trip[]
  payments       Payment[]
}

model Trip {
  id              String        @id @default(cuid())
  tripDate        DateTime
  place           String
  party           Party         @relation(fields: [partyId], references: [id])
  partyId         String
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id])
  vehicleId       String
  driver          Driver        @relation(fields: [driverId], references: [id])
  driverId        String
  ratePerKm       Float         @default(0)
  startingKm      Float         @default(0)
  endingKm        Float         @default(0)
  totalKm         Float         @default(0)
  dieselAmount    Float         @default(0)
  tollTax         Float         @default(0)
  borderTax       Float         @default(0)
  driverWages     Float         @default(0)
  miscExpense     Float         @default(0)
  tripAmount      Float         @default(0)
  finalBill       Float         @default(0)
  paymentStatus   PaymentStatus @default(PENDING)
  paidAmount      Float         @default(0)
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments        Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId        String
  party         Party    @relation(fields: [partyId], references: [id])
  partyId       String
  amount        Float
  paymentDate   DateTime
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AppSetting {
  id                      String   @id @default(cuid())
  companyName             String   @default("Transport Company")
  companyAddress          String?
  logoUrl                 String?
  invoiceFooter           String?
  currencySymbol          String   @default("₹")
  dateFormat              String   @default("dd/MM/yyyy")
  includeTollInBill       Boolean  @default(false)
  includeBorderInBill     Boolean  @default(false)
  includeDriverWagesInBill Boolean @default(false)
  includeDieselInBill     Boolean  @default(false)
  includeMiscInBill       Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
